{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Points & Miles Tracker",
  "description": "Schema for tracking airline loyalty points/miles across programs (Phase 2 feature)",
  "type": "object",
  "properties": {
    "user_id": {"type": "string"},
    "programs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "program_name": {"type": "string", "description": "e.g., American AAdvantage, United MileagePlus"},
          "program_code": {"type": "string"},
          "airline_code": {"type": "string"},
          "current_balance": {"type": "integer"},
          "elite_status": {"type": "string", "enum": ["none", "silver", "gold", "platinum", "diamond", "other"]},
          "expiration_date": {"type": "string", "format": "date", "description": "When points expire if applicable"},
          "last_updated": {"type": "string", "format": "date"},
          "notes": {"type": "string"}
        }
      }
    },
    "credit_card_points": {
      "type": "array",
      "description": "Transferable credit card points (Chase UR, Amex MR, etc.)",
      "items": {
        "type": "object",
        "properties": {
          "program_name": {"type": "string", "description": "e.g., Chase Ultimate Rewards, Amex Membership Rewards, Capital One Miles"},
          "current_balance": {"type": "integer"},
          "transfer_partners": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Airline programs these can transfer to"
          },
          "transfer_ratios": {
            "type": "object",
            "description": "Transfer ratio to each partner (e.g., {'UA': 1.0, 'BA': 1.0})"
          },
          "last_updated": {"type": "string", "format": "date"}
        }
      }
    },
    "redemption_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "date": {"type": "string", "format": "date"},
          "program": {"type": "string"},
          "points_used": {"type": "integer"},
          "cash_value_equivalent": {"type": "number"},
          "cents_per_point": {"type": "number"},
          "route": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    },
    "sweet_spot_alerts": {
      "type": "array",
      "description": "Known high-value redemption opportunities to watch for",
      "items": {
        "type": "object",
        "properties": {
          "program": {"type": "string"},
          "route_pattern": {"type": "string"},
          "typical_cpp": {"type": "number", "description": "Typical cents per point value"},
          "threshold_cpp": {"type": "number", "description": "Alert when CPP exceeds this"},
          "cabin_class": {"type": "string"},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
